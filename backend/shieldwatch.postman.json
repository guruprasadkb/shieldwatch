{
  "info": {
    "name": "ShieldWatch API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login as Admin",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"admin1\", \"password\": \"password123\"}"
        },
        "url": {"raw": "http://localhost:8080/api/auth/login", "host": ["http://localhost:8080"], "path": ["api", "auth", "login"]}
      }
    },
    {
      "name": "List Incidents",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "http://localhost:8080/api/incidents?page=0&size=10", "host": ["http://localhost:8080"], "path": ["api", "incidents"], "query": [{"key": "page", "value": "0"}, {"key": "size", "value": "10"}]}
      }
    },
    {
      "name": "Get Incident by ID",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "http://localhost:8080/api/incidents/inc-001", "host": ["http://localhost:8080"], "path": ["api", "incidents", "inc-001"]}
      }
    },
    {
      "name": "Create Incident",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token}}"}],
        "body": {
          "mode": "raw",
          "raw": "{\"title\": \"Suspicious login from new device\", \"description\": \"User logged in from unrecognized device and location\", \"severity\": \"MEDIUM\"}"
        },
        "url": {"raw": "http://localhost:8080/api/incidents", "host": ["http://localhost:8080"], "path": ["api", "incidents"]}
      }
    },
    {
      "name": "Transition Incident Status",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token}}"}],
        "body": {
          "mode": "raw",
          "raw": "{\"status\": \"TRIAGED\"}"
        },
        "url": {"raw": "http://localhost:8080/api/incidents/inc-001/transition", "host": ["http://localhost:8080"], "path": ["api", "incidents", "inc-001", "transition"]}
      }
    }
  ]
}
